# ──────────────────────────────────────────────
# Finandance Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# --- Supabase (PostgreSQL + Auth) ---
# Get these from your Supabase project settings
SUPABASE_URL=https://dgclzjtyfneztonwktyg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_publishable_WjIxqbHQ2RC3o1hqT84lZg_K-dZf11R
SUPABASE_JWT_SECRET=sb_secret_w0ceHMTncEJpJ56vUyhQQw_iXhgdlV4

# --- Encryption (Fernet MultiFernet) ---
# Comma-separated list of Fernet keys (first key encrypts, all can decrypt)
# Generate a key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# For key rotation: prepend a new key, keep the old one to decrypt existing data
MASTER_ENCRYPTION_KEY=0VNWiFHSzFw0E4uLMHB2_pg3T0sKv3CB_GtUt81aNsw=

# --- Application ---
ENVIRONMENT=development
# Use "production" in Railway/Render
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- APScheduler ---
# IMPORTANT: Backend MUST run with --workers 1 to avoid duplicate sync jobs
# See specs/001-finandance-mvp/quickstart.md for deployment notes
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Email Ingestion (n8n webhook) ---
# Shared secret between n8n HTTP Request node and the backend webhook endpoint
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=dev-webhook-secret-change-me

# --- Wise API (optional during development) ---
WISE_API_BASE_URL=https://api.transferwise.com

# --- Exchange Rate APIs ---
ECB_API_URL=https://data-api.ecb.europa.eu/service/data/EXR
COINGECKO_API_URL=https://api.coingecko.com/api/v3
